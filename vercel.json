{
  "version": 2,
  "buildCommand": "cd frontend && CI=false GENERATE_SOURCEMAP=false yarn build",
  "installCommand": "yarn --cwd frontend install",
  "outputDirectory": "frontend/build",
  "framework": "create-react-app",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
